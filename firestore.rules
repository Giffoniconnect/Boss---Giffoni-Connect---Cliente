rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // -------------------------------------------------------------------------
    // GLOBAL HELPERS
    // -------------------------------------------------------------------------
    
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }
    
    function isAdmin() {
      // Primary admin email always has access if signed in.
      // We also check for the boss_admin role in the users collection.
      return isSignedIn() && (
        request.auth.token.email == 'direito.rgr@gmail.com' ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'boss_admin'
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // -------------------------------------------------------------------------
    // CATCH-ALL DENY
    // -------------------------------------------------------------------------
    match /{document=**} {
      allow read, write: if false;
    }

    // -------------------------------------------------------------------------
    // USERS AND INVITES
    // -------------------------------------------------------------------------
    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin() || resource.data.email == request.auth.token.email);
      allow write: if isAdmin() || (isSignedIn() && request.auth.uid == userId && (
        // Allow self-registration if document doesn't exist
        !exists(/databases/$(database)/documents/users/$(userId))
      ));
    }

    match /users_invites/{inviteId} {
      allow read: if isAdmin() || (isSignedIn() && request.auth.token.email == resource.data.email);
      allow write: if isAdmin();
    }

    // -------------------------------------------------------------------------
    // CLIENT PORTALS (SLUG MAPPING)
    // -------------------------------------------------------------------------
    match /clientPortals/{slug} {
      allow read: if true; // Publicly readable to find the clientID by slug
      allow write: if isAdmin();
    }

    // -------------------------------------------------------------------------
    // CLIENTS COLLECTION
    // -------------------------------------------------------------------------
    match /clients/{clientId} {
      function isOwnClient() {
        return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.clientId == clientId;
      }

      allow read: if isAdmin() || isOwnClient();
      allow write: if isAdmin();
    }

    // -------------------------------------------------------------------------
    // CASES COLLECTION
    // -------------------------------------------------------------------------
    match /cases/{caseId} {
      function isValidCase(data) {
        return data.keys().hasAll(['clientId', 'title', 'status']) &&
               data.clientId is string &&
               data.title is string && data.title.size() <= 200 &&
               data.status is string;
      }

      function belongsToUser() {
        let userDoc = get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
        return isSignedIn() && (isAdmin() || (userDoc.role == 'client' && resource.data.clientId == userDoc.clientId));
      }

      allow read: if isAdmin() || belongsToUser();
      allow create: if isAdmin() && isValidCase(request.resource.data);
      allow update: if (isAdmin() && isValidCase(request.resource.data)) || 
                     (belongsToUser() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['lastUpdate'])); // Example: allow minimal updates if needed
      allow delete: if isAdmin();
    }

    // -------------------------------------------------------------------------
    // CASE SUB-RESOURCES (Events, Docs, Financial, Comms)
    // -------------------------------------------------------------------------
    
    function canAccessCase(caseId) {
      let caseData = get(/databases/$(database)/documents/cases/$(caseId)).data;
      let userDoc = get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
      return isAdmin() || (userDoc.role == 'client' && caseData.clientId == userDoc.clientId);
    }

    function isVisibleToClient(data) {
      return data.get('visibleToClient', false) == true;
    }

    match /caseEvents/{eventId} {
      allow read: if isAdmin() || (isSignedIn() && canAccessCase(resource.data.caseId) && isVisibleToClient(resource.data));
      allow write: if isAdmin();
    }

    match /casePendingTasks/{taskId} {
      allow read: if isAdmin() || (isSignedIn() && canAccessCase(resource.data.caseId) && isVisibleToClient(resource.data));
      allow write: if isAdmin();
    }

    match /caseExplanations/{explId} {
      allow read: if isAdmin() || (isSignedIn() && canAccessCase(resource.data.caseId) && isVisibleToClient(resource.data));
      allow write: if isAdmin();
    }

    match /caseDocuments/{docId} {
      allow read: if isAdmin() || (isSignedIn() && canAccessCase(resource.data.caseId) && isVisibleToClient(resource.data));
      allow write: if isAdmin();
    }

    match /caseFinancials/{finId} {
      allow read: if isAdmin() || (isSignedIn() && canAccessCase(resource.data.caseId) && isVisibleToClient(resource.data));
      allow write: if isAdmin();
    }

    match /caseCommunications/{commId} {
      allow read: if isAdmin() || (isSignedIn() && canAccessCase(resource.data.caseId) && isVisibleToClient(resource.data));
      allow create: if isSignedIn() && (isAdmin() || (canAccessCase(request.resource.data.caseId) && request.resource.data.clientId == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.clientId));
      allow update, delete: if isAdmin();
    }

    // -------------------------------------------------------------------------
    // CASE INFORMATION REQUESTS
    // -------------------------------------------------------------------------
    match /caseInformationRequests/{requestId} {
      function canAccessRequest(data) {
        let userDoc = get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
        return isAdmin() || (userDoc.role == 'client' && data.clientId == userDoc.clientId && data.get('visibleToClient', false) == true);
      }

      allow read: if isSignedIn() && canAccessRequest(resource.data);
      allow create: if isAdmin();
      allow update: if (isAdmin()) || (isSignedIn() && canAccessRequest(resource.data) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['answer', 'status', 'updatedAt']));
      allow delete: if isAdmin();
    }

    // -------------------------------------------------------------------------
    // CASE EVIDENCE REQUESTS
    // -------------------------------------------------------------------------
    match /caseEvidenceRequests/{requestId} {
      function canAccessEvidenceRequest(data) {
        let userDoc = get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
        return isAdmin() || (userDoc.role == 'client' && data.clientId == userDoc.clientId && data.get('visibleToClient', false) == true);
      }

      allow read: if isSignedIn() && canAccessEvidenceRequest(resource.data);
      allow create: if isAdmin();
      allow update: if (isAdmin()) || (isSignedIn() && canAccessEvidenceRequest(resource.data) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['files', 'status', 'updatedAt']));
      allow delete: if isAdmin();
    }

    // -------------------------------------------------------------------------
    // SETTINGS COLLECTION
    // -------------------------------------------------------------------------
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin() && (settingId != 'portal' || (
        request.resource.data.keys().hasAll(['link']) &&
        request.resource.data.link is string &&
        request.resource.data.link.size() <= 2048
      ));
    }

    // -------------------------------------------------------------------------
    // MASTER EDITOR LOGS COLLECTION
    // -------------------------------------------------------------------------
    match /masterEditorLogs/{logId} {
      allow read, write: if isAdmin();
    }

    // -------------------------------------------------------------------------
    // CREDENCIAIS CLIENTE COLLECTION (PORTAL CLIENT AUTHENTICATION)
    // -------------------------------------------------------------------------
    match /credenciaisCliente/{credId} {
      allow read: if true; // Public read permitted for authentication
      allow write: if isAdmin();
    }

    // -------------------------------------------------------------------------
    // CLIENTES COLLECTION (CLIENT PORTAL READ COMPATIBILITY)
    // -------------------------------------------------------------------------
    match /clientes/{clientId} {
      function isOwnCliente() {
        return isSignedIn() && (
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.clientId == clientId ||
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.clientId == resource.data.clientId
        );
      }

      allow read: if isAdmin() || isOwnCliente();
      allow write: if isAdmin();
    }

    // -------------------------------------------------------------------------
    // CASOS COLLECTION (CASE READ COMPATIBILITY)
    // -------------------------------------------------------------------------
    match /casos/{casoId} {
      function belongsToUserCaso() {
        let userDoc = get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
        return isSignedIn() && (
          isAdmin() || (
            userDoc.role == 'client' && (
              resource.data.clientId == userDoc.clientId || 
              resource.data.clienteId == userDoc.clientId
            )
          )
        );
      }
      function isCasoVisible() {
        return resource.data.get('visivelParaCliente', false) == true || 
               resource.data.get('visibleToClient', false) == true;
      }

      allow read: if isAdmin() || (belongsToUserCaso() && isCasoVisible());
      allow write: if isAdmin();
    }
  }
}
