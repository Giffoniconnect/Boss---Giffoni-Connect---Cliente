    "ClientPortal": {
      "title": "Client Portal Link",
      "description": "Mapping from slugs to client IDs.",
      "type": "object",
      "properties": {
        "clientId": { "type": "string" },
        "slug": { "type": "string" }
      },
      "required": ["clientId", "slug"]
    },
    "User": {
      "title": "Platform User",
      "description": "User profile with role-based access.",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["boss_admin", "client"] },
        "clientId": { "type": "string" }
      },
      "required": ["email", "role"]
    },
    "Case": {
      "title": "Legal Case",
      "description": "The central entity for legal process tracking.",
      "type": "object",
      "properties": {
        "clientId": { "type": "string" },
        "title": { "type": "string" },
        "processNumber": { "type": "string" },
        "actionType": { "type": "string" },
        "court": { "type": "string" },
        "district": { "type": "string" },
        "tribunal": { "type": "string" },
        "responsibleLawyer": { "type": "string" },
        "status": { "type": "string" },
        "priority": { "type": "string" },
        "lastUpdate": { "type": "string" },
        "description": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["clientId", "title", "status"]
    },
    "CaseEvent": {
      "title": "Case Event",
      "description": "Audiences, meetings, expertises, and deadlines.",
      "type": "object",
      "properties": {
        "caseId": { "type": "string" },
        "clientId": { "type": "string" },
        "type": { "type": "string", "enum": ["audiencia", "pericia", "reuniao", "prazo", "compromisso"] },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "time": { "type": "string" },
        "location": { "type": "string" },
        "status": { "type": "string", "enum": ["agendado", "realizado", "cancelado", "remarcado"] },
        "visibleToClient": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["caseId", "clientId", "type", "title", "date"]
    },
    "CasePendingTask": {
      "title": "Case Pending Task",
      "description": "Tasks or documents requested from the client.",
      "type": "object",
      "properties": {
        "caseId": { "type": "string" },
        "clientId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "type": { "type": "string", "enum": ["documento", "confirmacao", "assinatura", "informacao", "outro"] },
        "status": { "type": "string", "enum": ["pendente", "concluido", "vencido"] },
        "dueDate": { "type": "string", "format": "date" },
        "visibleToClient": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["caseId", "clientId", "title", "status"]
    },
    "CaseExplanation": {
      "title": "Case Explanation",
      "description": "Giffoni Explica: Manual explanations for the client.",
      "type": "object",
      "properties": {
        "caseId": { "type": "string" },
        "clientId": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "category": { "type": "string", "enum": ["andamento", "decisao", "audiencia", "pericia", "financeiro", "geral"] },
        "visibleToClient": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["caseId", "clientId", "title", "content"]
    },
    "CaseDocument": {
      "title": "Case Document",
      "description": "Linked documents, proofs, and pending uploads.",
      "type": "object",
      "properties": {
        "caseId": { "type": "string" },
        "clientId": { "type": "string" },
        "title": { "type": "string" },
        "type": { "type": "string" },
        "url": { "type": "string" },
        "status": { "type": "string", "enum": ["vinculado", "solicitado", "pendente"] },
        "visibleToClient": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["caseId", "clientId", "title", "status"]
    },
    "CaseFinancial": {
      "title": "Case Financial",
      "description": "Honorariums and payment tracking.",
      "type": "object",
      "properties": {
        "caseId": { "type": "string" },
        "clientId": { "type": "string" },
        "totalAmount": { "type": "number" },
        "status": { "type": "string" },
        "installments": { "type": "number" },
        "installmentsPaid": { "type": "number" },
        "nextDueDate": { "type": "string", "format": "date-time" },
        "visibleToClient": { "type": "boolean" }
      },
      "required": ["caseId", "clientId", "status"]
    },
    "CaseCommunication": {
      "title": "Case Communication",
      "description": "Messages, requests, and 'Giffoni Explica'.",
      "type": "object",
      "properties": {
        "caseId": { "type": "string" },
        "clientId": { "type": "string" },
        "senderId": { "type": "string" },
        "content": { "type": "string" },
        "type": { "type": "string", "enum": ["mensagem", "solicitacao", "aviso", "explicacao"] },
        "visibleToClient": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["caseId", "clientId", "content", "type"]
    },
    "SystemSetting": {
      "title": "System Setting",
      "description": "Global settings for portal links and parameters.",
      "type": "object",
      "properties": {
        "link": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["link"]
    },
    "CaseInformationRequest": {
      "title": "Case Information Request",
      "description": "Factual questions requested from the client for a specific case.",
      "type": "object",
      "properties": {
        "caseId": { "type": "string" },
        "clientId": { "type": "string" },
        "question": { "type": "string" },
        "answer": { "type": "string" },
        "status": { "type": "string", "enum": ["pendente", "respondido", "revisado"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["caseId", "clientId", "question", "status"]
    },
    "CaseEvidenceRequest": {
      "title": "Case Evidence Request",
      "description": "Evidence documents requested from the client for a specific case.",
      "type": "object",
      "properties": {
        "caseId": { "type": "string" },
        "clientId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "status": { "type": "string", "enum": ["pendente", "entregue", "aprovado", "rejeitado", "revisao_solicitada"] },
        "files": {
          "type": "array"
        },
        "googleDriveFolderId": { "type": "string" },
        "googleDriveFileId": { "type": "string" },
        "googleDriveFileUrl": { "type": "string" },
        "driveSyncStatus": { "type": "string", "enum": ["nao_sincronizado", "sincronizando", "sincronizado", "erro"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["caseId", "clientId", "title", "status"]
    },
    "MasterEditorLog": {
      "title": "Master Editor Log",
      "description": "Logs of changes made via the Master Client Editor area.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "clientId": { "type": "string" },
        "caseId": { "type": "string" },
        "areaChanged": { "type": "string" },
        "action": { "type": "string" },
        "previousValue": { "type": "string" },
        "newValue": { "type": "string" },
        "changedBy": { "type": "string" },
        "changedAt": { "type": "string", "format": "date-time" },
        "reason": { "type": "string" }
      },
      "required": ["id", "clientId", "areaChanged", "action", "changedBy", "changedAt"]
    },
    "GoogleDriveJob": {
      "title": "Google Drive Job",
