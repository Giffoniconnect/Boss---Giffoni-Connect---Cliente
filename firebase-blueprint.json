        "updatedAt": { "type": "string", "format": "date-time" },
        "caseId": { "type": "string" },
        "portalClientId": { "type": "string" },
        "clientType": { "type": "string" },
        "destinationFolderId": { "type": "string" },
        "destinationFolderUrl": { "type": "string" },
        "templateKey": { "type": "string" },
        "payload": {
          "type": "object",
          "properties": {
            "nomeCompleto": { "type": "string" },
            "nacionalidade": { "type": "string" },
            "estadoCivil": { "type": "string" },
            "profissao": { "type": "string" },
            "cpf": { "type": "string" },
            "rg": { "type": "string" },
            "endereco": { "type": "string" },
            "numero": { "type": "string" },
            "complemento": { "type": "string" },
            "bairro": { "type": "string" },
            "cidade": { "type": "string" },
            "estado": { "type": "string" },
            "cep": { "type": "string" },
            "email": { "type": "string" },
            "telefone": { "type": "string" },
            "whatsapp": { "type": "string" },
            "localAssinatura": { "type": "string" },
            "advogadoNome": { "type": "string" },
            "advogadoOab": { "type": "string" },
            "dataAssinatura": { "type": "string" }
          }
        },
        "result": {
          "type": "object",
          "properties": {
            "googleDocsId": { "type": "string" },
            "googleDocsUrl": { "type": "string" },
            "fileName": { "type": "string" }
          }
        },
        "errorCode": { "type": "string" },
        "errorMessage": { "type": "string" },
