        "portalClientId": { "type": "string" },
        "caseId": { "type": "string" },
        "clientFolderName": { "type": "string" },
        "originBlock": { "type": "string" },
        "originField": { "type": "string" },
        "folderId": { "type": "string" },
        "folderUrl": { "type": "string" },
        "googleDriveClientFolderId": { "type": "string" },
        "googleDriveClientFolderUrl": { "type": "string" },
        "errorMessage": { "type": "string" },
        "processedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["status", "clientType", "portalClientId", "caseId", "clientFolderName", "createdAt"]
    },
